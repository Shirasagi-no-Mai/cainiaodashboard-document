import pandas as pd
import os
import math
from datetime import datetime


def check_na(val):
    """判断是否为空或N/A，返回横杠或空字符串"""
    s = str(val).strip().upper()
    if s in ["N/A", "0", "0.0", "", "-", "NONE"]:
        return "-"
    return ""


