def generate_summary_report(BASE_DIR, SOURCE_FILES):
    """
    从所有源文件中提取字段，生成「精算汇总表.xlsx」
    修复：解决时区报错、防止日期变空、恢复看板筛选
    """
    import pandas as pd
    import os
    from datetime import datetime
    from dateutil import parser  # 导入强力解析器

    summary_rows = []
    summary_columns = ["主单号", "口岸", "客户", "航班号", "ETA", "总箱数", "总包裹数", "总重量"]

    # 1. 强力日期解析函数：解决时区报错 + 防止变空
    def robust_parse_eta(val):
        if pd.isna(val) or str(val).strip() == "" or str(val).lower() == "nan":
            return pd.NaT

        # 如果已经是时间对象
        if isinstance(val, (datetime, pd.Timestamp)):
            return val.replace(tzinfo=None) if hasattr(val, 'tzinfo') else val

        try:
            # 尝试用 dateutil 智能解析字符串
            # 它能处理 2026-03-11T14:00:00+08:00 这种带时区的格式
            dt = parser.parse(str(val))
            return dt.replace(tzinfo=None)  # 强制抹除时区，防止 compare 报错
        except:
            # 如果智能解析失败，尝试 pandas 最后的努力
            ts = pd.to_datetime(val, errors='coerce')
            if ts is not pd.NaT:
                return ts.tz_localize(None) if ts.tz is not None else ts
            return pd.NaT

    for base_name in SOURCE_FILES:
        src_path = os.path.join(BASE_DIR, f"{base_name}.xlsx")
        if not os.path.exists(src_path):
            continue

        print(f"📊 正在汇总: {base_name}")
        try:
            # 读取最近 100 行，确保包含 11 号后的最新数据
            df_src = pd.read_excel(src_path).tail(6000)
        except Exception as e:
            print(f"  ⚠️ 读取失败 {base_name}: {e}")
            continue

        parts = base_name.split("-", 1)
        port = parts[0] if len(parts) > 0 else ""
        customer = parts[1] if len(parts) > 1 else ""

        for _, row in df_src.iterrows():
            # 提取主单号
            mawb = ""
            for col in ["MAWB", "主单", "主单号"]:
                if col in df_src.columns and pd.notna(row[col]):
                    mawb = str(row[col]).strip()
                    break

            if not mawb or mawb.lower() == "nan":
                continue

            # 提取其他字段
            flight = row.get("航班号") or row.get("Flight Number") or ""
            eta = row.get("ETA", "")
            total_ctn = row.get("总箱数") or row.get("Total CTN") or ""
            total_parcels = row.get("总包裹数") or row.get("Total Parcels") or ""
            weight = row.get("总重量") or row.get("Weight") or ""

            summary_rows.append({
                "主单号": mawb, "口岸": port, "客户": customer, "航班号": flight,
                "ETA": eta, "总箱数": total_ctn, "总包裹数": total_parcels, "总重量": weight
            })

    if summary_rows:
        df_summary = pd.DataFrame(summary_rows, columns=summary_columns)

        # --- 核心日期修复环节 ---
        # 应用强力解析，确保这一列全是“无时区的时间对象”
        df_summary["ETA"] = df_summary["ETA"].apply(robust_parse_eta)

        # 再次确保列类型是 datetime（这样 Excel 才会出现日期筛选器）
        df_summary["ETA"] = pd.to_datetime(df_summary["ETA"], errors='coerce')

        # 排序：按 ETA 升序，新单子会按时间顺序排列，空日期排最后
        df_summary = df_summary.sort_values(by="ETA", ascending=True, na_position='last')
        df_summary = df_summary.reset_index(drop=True)
        # -----------------------

        summary_path = os.path.join(BASE_DIR, "精算汇总表.xlsx")

        # 特别注意：update_excel_file 内部必须不能有 .astype(str)
        update_excel_file(summary_path, df_summary)
        print(f"✅ 汇总完成！ETA 报错已修正，看板筛选器已尝试恢复。")
    else:
        print("📊 未找到任何数据。")


