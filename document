def run_main():
    input_date, month_abbr = get_local_time()
    registry = get_logic_registry(input_date, month_abbr)

    for base_name in SOURCE_FILES:
        src_path = os.path.join(BASE_DIR, f"{base_name}.xlsx")
        if not os.path.exists(src_path):
            continue

        if base_name not in registry:
            print(f"⚠️ 跳过 {base_name}: 注册表中未定义逻辑")
            continue

        print(f"🚀 正在处理: {base_name}")
        df_src = pd.read_excel(src_path).tail(6000)

        for task in registry[base_name]:
            target_path = os.path.join(BASE_DIR, f"{base_name}{task['suffix']}.xlsx")
            mapping = task['mapping']

            new_rows = []
            for _, row in df_src.iterrows():
                new_item = {}
                for target_col, src_ref in mapping.items():
                    if callable(src_ref):
                        new_item[target_col] = src_ref(row)
                    elif src_ref in df_src.columns:
                        val = row[src_ref]
                        new_item[target_col] = val if pd.notna(val) else ""
                    else:
                        new_item[target_col] = src_ref
                new_rows.append(new_item)

            if new_rows:
                # --- ✨ 关键修改点：强制指定列顺序 ---
                df_final = pd.DataFrame(new_rows, columns=list(mapping.keys()))
                update_excel_file(target_path, df_final)
    generate_summary_report(BASE_DIR, SOURCE_FILES)


if __name__ == "__main__":
    run_main()
