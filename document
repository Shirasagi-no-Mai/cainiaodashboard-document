BASE_DIR = os.path.join(os.path.expanduser("~"), "Desktop", "测试文件夹")
SOURCE_FILES = ["LAX-4PX", "LAX-AE", "MIA-4PX", "MIA-AE", "ORD-4PX", "ORD-AE"]


def get_local_time():
    now = datetime.now()
    return f"{now.month}/{now.day}", now.strftime('%b').upper()


def update_excel_file(target_path, df_new):
    """保存并去重：智能兼容‘主单’、‘主单号’、‘MAWB’"""
    if os.path.exists(target_path):
        # 1. 读取旧数据，强制转为字符串处理，防止 0123 这种单号被读成数字导致对比失败
        df_old = pd.read_excel(target_path).astype(str)

        # 2. 智能寻找“主单列”：按优先级匹配你提到的三个名字
        key_col = None
        potential_keys = ["主单", "主单号", "MAWB", "MAWB#"]

        # 先从新表里找这个“钥匙”列叫什么
        for k in potential_keys:
            if k in df_new.columns:
                key_col = k
                break

        # 如果新表里还是找不到（比如 4PX 突然改名叫 Master Waybill），则保底用第一列
        if not key_col:
            key_col = df_new.columns[0]

        # 3. 数据清洗：去掉前后的空格，防止 "MAWB123 " 和 "MAWB123" 被当作两个单号
        old_keys_set = set(df_old[key_col].str.strip().tolist())

        # 4. 核心去重：只保留那些“主单号”不在旧表里的行
        # 使用 .astype(str).str.strip() 确保两边格式绝对统一
        df_new_filtered = df_new[~df_new[key_col].astype(str).str.strip().isin(old_keys_set)]

        if not df_new_filtered.empty:
            # 5. 合并并保存：保持新表的列顺序（即 mapping 里的顺序）
            pd.concat([df_old, df_new_filtered], ignore_index=True).to_excel(target_path, index=False)
            print(f"  ✅ 追加 {len(df_new_filtered)} 条新数据至 {os.path.basename(target_path)}")
        else:
            print(f"  ☕ {os.path.basename(target_path)} 中所有单号已存在，跳过。")
    else:
        # 如果文件不存在，直接创建
        df_new.to_excel(target_path, index=False)
        print(f"  ✨ 初始创建文件: {os.path.basename(target_path)}")


