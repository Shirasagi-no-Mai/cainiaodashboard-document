                                                     ceil_val(r.get("OC UNIUNI CTN"), 20) + ceil_val(
                                                 r.get("YW EXP CTN"), 20)
                                             ) * 12,
                    "COE/UP": lambda r: ceil_val(r.get("COE/UP CTN"), 20),
